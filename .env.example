# ===== Core =====
ENVIRONMENT=development
LOG_LEVEL=INFO

# ===== Database =====
POSTGRES_USER=jobhunter
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobhunter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://jobhunter:changeme@postgres:5432/jobhunter
# For Alembic / sync tooling
DATABASE_URL_SYNC=postgresql+psycopg://jobhunter:changeme@postgres:5432/jobhunter

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== MinIO / S3 =====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=jobhunter
MINIO_USE_SSL=false

# ===== Auth =====
JWT_SECRET=replace-with-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ===== Encryption =====
# Fernet key: 32 url-safe base64 bytes. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=replace-with-fernet-key

# ===== LLM =====
ANTHROPIC_API_KEY=sk-ant-xxxxx
LLM_MODEL_SCORING=claude-haiku-4-5-20251001
LLM_MODEL_GENERATION=claude-sonnet-4-6

# ===== Frontend (Vite reads VITE_*) =====
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ===== Observability =====
SENTRY_DSN=

# ===== Admin bootstrap =====
# On first boot, if no admin exists and these are set, an admin user is created.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ===== Rate limits =====
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_LLM_PER_MIN=10
